<?xml version='1.0' encoding='utf-8'?>
<widget id="cl.eva.examencomponentes" version="1.0.0" xmlns="http://www.w3.org/ns/widgets">
  <name>Eva Examen Componentes</name>
  <description>Aplicación React empaquetable con Cordova para Android.</description>
  <author email="alumno@example.com" href="https://example.com">Equipo de Programación de Componentes</author>
  <content src="index.html" />
  <access origin="*" />
  <allow-intent href="http://*/*" />
  <allow-intent href="https://*/*" />
  <allow-intent href="tel:*" />
  <allow-intent href="sms:*" />
  <allow-intent href="mailto:*" />
  <allow-intent href="geo:*" />
  <platform name="android">
    <preference name="android-minSdkVersion" value="23" />
    <preference name="android-targetSdkVersion" value="35" />
  </platform>
</widget>
